# ===========================================
# MARMAILLE PARC + FOOT — Configuration
# ===========================================
# Copiez ce fichier en .env.local et remplissez les valeurs

# ---- Base de données ----
# SQLite (développement local)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production — recommandé)
# DATABASE_URL="postgresql://user:password@localhost:5432/marmaille_parc"

# ---- Stripe ----
# Clés disponibles sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"

# ---- Email (Resend — gratuit jusqu'à 3000 emails/mois) ----
# Compte sur https://resend.com
RESEND_API_KEY="your_resend_api_key_here"
FROM_EMAIL="noreply@votre-domaine.re"

# ---- Admin ----
# Token secret pour l'API admin (changez en production !)
ADMIN_SECRET="votre-token-admin-secret-longue-chaine"
ADMIN_PASSWORD="admin2024"

# ---- Infos parc ----
PARK_PHONE="0692 XX XX XX"
NEXT_PUBLIC_PARK_NAME="Marmaille Parc + Foot"
